{
  "name": "@dorafactory/zkstark-amaci",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Independent Stark/STARK proof-layer prototype for AMACI tally and process-message circuits",
  "dependencies": {
    "@zk-kit/baby-jubjub": "^1.0.3",
    "@zk-kit/eddsa-poseidon": "^1.1.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:msg": "node --test tests/process-messages.test.mjs",
    "test:cairo": "cd cairo && scarb test",
    "test:cairo-execute": "RUN_CAIRO_EXECUTION_TESTS=1 node --test tests/cairo-execution.test.mjs",
    "test:contracts": "cd contracts && scarb test",
    "discover:fixtures": "node tools/discover-amaci-fixtures.mjs",
    "execute:circuit": "node tools/run-cairo-execute.mjs",
    "write:small-fixture": "node tools/write-small-fixture.mjs",
    "prepare:circuit": "node tools/prepare-amaci-circuit-input.mjs",
    "prepare:msg": "node tools/prepare-process-messages-input.mjs",
    "prepare:add-new-key": "node tools/prepare-add-new-key-input.mjs",
    "prepare:ecdh": "node tools/prepare-ecdh-input.mjs",
    "prepare:process-one": "node tools/prepare-process-one-input.mjs",
    "prepare:process-one-ecdh": "node tools/prepare-process-one-with-ecdh-input.mjs",
    "prepare:process-deactivate-one": "node tools/prepare-process-deactivate-one-input.mjs",
    "prepare:process-deactivate-boundary": "node tools/prepare-process-deactivate-boundary-input.mjs",
    "prepare:process-deactivate-stateful": "node tools/prepare-process-deactivate-stateful-input.mjs",
    "prepare:msg-state": "node tools/prepare-process-messages-state-input.mjs",
    "prepare:msg-stateful": "node tools/prepare-process-messages-stateful-input.mjs",
    "prepare:msg-stateful-ecdh": "node tools/prepare-process-messages-stateful-with-ecdh-input.mjs",
    "prepare:msg-stateful-ecdh-signature": "node tools/prepare-process-messages-stateful-with-ecdh-signature-input.mjs",
    "prepare:tally": "node tools/prepare-tally-input.mjs fixtures/tally-small/000000.json",
    "prepare:cairo-input": "node tools/prepare-tally-input.mjs fixtures/tally-small/000000.json --out /tmp/zkstark-amaci-prepared.json --cairo-input-out /tmp/zkstark-amaci-cairo-input.json",
    "prepare:cairo-args": "node tools/prepare-tally-input.mjs fixtures/tally-small/000000.json --out /tmp/zkstark-amaci-prepared.json --cairo-args-out /tmp/zkstark-amaci-cairo-args.json",
    "prove:circuit": "tools/run-cairo-proof.sh",
    "prove:tally": "tools/run-cairo-proof.sh --circuit tally --input fixtures/tally-small/000000.json",
    "prove:all-small": "tools/run-cairo-proof.sh --all --tally-input fixtures/tally-small/000000.json",
    "export:hash-vectors": "node tools/export-hash-vectors.mjs fixtures/tally-small/000000.json",
    "verify:hash-vectors": "node tools/verify-hash-vectors.mjs /tmp/zkstark-amaci-hash-vectors.json",
    "generate:poseidon-cairo-constants": "node tools/generate-poseidon-cairo-constants.mjs cairo/src/poseidon_constants.cairo",
    "verify:poseidon-cairo-constants": "node tools/verify-poseidon-cairo-constants.mjs cairo/src/poseidon_constants.cairo"
  }
}
